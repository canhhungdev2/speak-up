# -----------------------------------------------------------------------------
# SPEAKUP ENVIRONMENT VARIABLES EXAMPLE
# -----------------------------------------------------------------------------

# [Database]
# Chuỗi kết nối tới cơ sở dữ liệu PostgreSQL (ví dụ: Supabase hoặc Local Postgres)
# Định dạng: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/speak_up

# [Storage]
# Đường dẫn tuyệt đối tới thư mục lưu trữ Media (Ảnh, Audio, VTT) bên ngoài dự án
# Đảm bảo thư mục này có quyền ghi (Write Permission)
STORAGE_PATH=E:/Workspace/MyProject/Storage/speak-up-storage

# [Server]
# Cổng chạy ứng dụng Backend (mặc định: 3000)
PORT=3000

# [Authentication - Future Use]
# SUPABASE_JWT_SECRET=your_super_secret_key_here

